<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!-- 阿里巴巴 Java 开发规范 Checkstyle 配置（嵩山版） -->
<module name="Checker">

    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <module name="SuppressionFilter">
        <property name="file" value="${config_loc}/checkstyle-suppressions.xml"/>
        <property name="optional" value="true"/>
    </module>

    <!-- 禁止 Tab 缩进 -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- 文件末尾必须有换行符 -->
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf_cr_crlf"/>
    </module>

    <!-- 单行最大 150 字符，忽略 import/package/URL -->
    <module name="LineLength">
        <property name="max" value="150"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- 禁止行尾空格 -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="minimum" value="0"/>
        <property name="maximum" value="0"/>
        <property name="message" value="行尾不允许有空格"/>
    </module>

    <module name="TreeWalker">

        <module name="SuppressWarningsHolder"/>

        <!-- 支持 // CHECKSTYLE:OFF ... CHECKSTYLE:ON 局部关闭 -->
        <module name="SuppressionCommentFilter">
            <property name="offCommentFormat" value="CHECKSTYLE:OFF"/>
            <property name="onCommentFormat" value="CHECKSTYLE:ON"/>
        </module>

        <!-- ===== 命名规范（阿里规约第一章）===== -->

        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="类名 ''{0}'' 须用 UpperCamelCase"/>
        </module>

        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="方法名 ''{0}'' 须用 lowerCamelCase"/>
        </module>

        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="参数名 ''{0}'' 须用 lowerCamelCase"/>
        </module>

        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="局部变量名 ''{0}'' 须用 lowerCamelCase"/>
        </module>

        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="成员变量名 ''{0}'' 须用 lowerCamelCase"/>
        </module>

        <!-- static final 常量须全大写+下划线 -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
            <message key="name.invalidPattern" value="常量名 ''{0}'' 须用 UPPER_SNAKE_CASE"/>
        </module>

        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
            <message key="name.invalidPattern" value="包名 ''{0}'' 须全小写"/>
        </module>

        <!-- ===== 常量定义（阿里规约第二章）===== -->

        <!-- 禁止魔法数字，豁免 -1/0/1/2 -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreAnnotation" value="true"/>
            <property name="ignoreFieldDeclaration" value="true"/>
            <property name="ignoreHashCodeMethod" value="true"/>
            <message key="magic.number" value="魔法数字 ''{0}'' 须定义为 static final 常量"/>
        </module>

        <!-- ===== 导入规范 ===== -->

        <module name="AvoidStarImport">
            <message key="import.avoidStar" value="禁止通配符导入 ''{0}''"/>
        </module>

        <module name="UnusedImports">
            <property name="processJavadoc" value="false"/>
        </module>

        <module name="RedundantImport"/>

        <!-- ===== 代码格式（阿里规约第五章）===== -->

        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="arrayInitIndent" value="4"/>
        </module>

        <!-- if/else/for/while 必须加大括号 -->
        <module name="NeedBraces">
            <message key="needBraces" value="''{0}'' 语句必须使用大括号"/>
        </module>

        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>

        <module name="RightCurly">
            <property name="option" value="alone"/>
            <property name="tokens"
                      value="LITERAL_TRY, LITERAL_CATCH, LITERAL_FINALLY, LITERAL_IF, LITERAL_ELSE, CLASS_DEF, METHOD_DEF, CTOR_DEF, LITERAL_FOR, LITERAL_WHILE, STATIC_INIT, INSTANCE_INIT"/>
        </module>

        <module name="WhitespaceAfter">
            <property name="tokens"
                      value="COMMA, SEMI, TYPECAST, LITERAL_IF, LITERAL_ELSE, LITERAL_WHILE, LITERAL_DO, LITERAL_FOR, LITERAL_FINALLY, DO_WHILE"/>
        </module>

        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyLambdas" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
            <property name="ignoreEnhancedForColon" value="false"/>
        </module>

        <module name="NoWhitespaceBefore">
            <property name="tokens" value="SEMI, DOT"/>
            <property name="allowLineBreaks" value="true"/>
        </module>

        <!-- 禁止一行声明多个变量 -->
        <module name="MultipleVariableDeclarations"/>

        <!-- 方法不超过 80 行（不含空行） -->
        <module name="MethodLength">
            <property name="max" value="80"/>
            <property name="countEmpty" value="false"/>
            <message key="maxLen.method" value="方法 {0} 行超过 80 行上限，建议拆分"/>
        </module>

        <!-- 方法参数不超过 5 个 -->
        <module name="ParameterNumber">
            <property name="max" value="5"/>
            <property name="tokens" value="METHOD_DEF"/>
            <message key="maxParam" value="方法参数 {0} 个超过 5 个上限"/>
        </module>

        <!-- ===== 异常处理（阿里规约第六章）===== -->

        <!-- catch 块不能为空，变量名为 expected/ignore 时豁免 -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignore"/>
            <message key="catch.block.empty" value="catch 块不能为空，须有处理逻辑或说明注释"/>
        </module>

        <!-- if 嵌套不超过 3 层 -->
        <module name="NestedIfDepth">
            <property name="max" value="3"/>
            <message key="nested.if.depth" value="if 嵌套 {0} 层超过 3 层，建议用卫语句或提取方法"/>
        </module>

        <module name="NestedTryDepth">
            <property name="max" value="2"/>
            <message key="nested.try.depth" value="try 嵌套 {0} 层超过 2 层"/>
        </module>

        <!-- ===== OOP 规范 ===== -->

        <!-- 重写 equals 必须同时重写 hashCode -->
        <module name="EqualsHashCode"/>

        <!-- 字符串比较禁止用 == -->
        <module name="StringLiteralEquality"/>

        <module name="ModifierOrder"/>

        <module name="RedundantModifier"/>

        <!-- ===== Switch 规范 ===== -->

        <module name="MissingSwitchDefault">
            <message key="missing.switch.default" value="switch 必须包含 default 分支"/>
        </module>

        <!-- case 穿透须加注释（含 falls?through/without break/intentional 字样） -->
        <module name="FallThrough">
            <property name="reliefPattern" value="falls?[ -]?thr(ough|u)|without break|intentional"/>
            <message key="fall.through" value="case 缺少 break/return/throw，有意穿透请加注释说明"/>
        </module>

        <!-- ===== 注释规范 ===== -->

        <!-- public 类/接口/枚举必须有 Javadoc -->
        <module name="MissingJavadocType">
            <property name="scope" value="public"/>
            <property name="tokens" value="CLASS_DEF, INTERFACE_DEF, ENUM_DEF, RECORD_DEF, ANNOTATION_DEF"/>
            <message key="javadoc.missing" value="public 类/接口/枚举必须有 Javadoc 注释"/>
        </module>

    </module>

    <module name="SuppressWarningsFilter"/>

</module>
